    "section_7520_rate_basis_points": {
      "unit": "basis_points",
      "scale": "1 percent = 100 basis points"
    }
  },
  "storage": {
    "primary_records": "by-year/YYYY-section-7520-rates.json",
    "year_shards": "by-year/YYYY-section-7520-rates.json",
    "ordering": "ascending_effective_month",
    "dedupe_key": "effective_month"
  },
  "dataset_id": "section-7520-rates",
  "schema_id": "rates.section_7520_rates.v1",
  "schema_version": 1,
  "proto": {
    "file": "proto/rates/v1/section_7520_rates.proto",
    "message": "rates.v1.Section7520RateFile"
  }
