{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/vanderbr/rates/main/schemas/v1/treasury-yield-curve.schema.json",
  "title": "treasury-yield-curve",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "date",
      "par_yields_basis_points"
    ],
    "properties": {
      "date": {
        "type": "string"
      },
      "par_yields_basis_points": {
        "type": "array",
        "items": {
          "type": [
            "integer",
            "null"
          ]
        }
      }
    }
  }
}
