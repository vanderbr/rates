{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/vanderbr/rates/main/schemas/v1/gst-exemption.schema.json",
  "title": "gst-exemption",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "period_start_date",
      "period_end_date",
      "exemption_amount_usd",
      "applies_to"
    ],
    "properties": {
      "period_start_date": {
        "type": "string"
      },
      "period_end_date": {
        "type": "string"
      },
      "exemption_amount_usd": {
        "type": "integer",
        "minimum": 0
      },
      "applies_to": {
        "type": "string"
      }
    }
  }
}
