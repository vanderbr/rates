{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/vanderbr/rates/main/schemas/v1/federal-funds.schema.json",
  "title": "federal-funds",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "date",
      "rate_basis_points"
    ],
    "properties": {
      "date": {
        "type": "string"
      },
      "rate_basis_points": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
