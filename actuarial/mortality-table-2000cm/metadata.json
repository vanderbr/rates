  "value_fields": {
    "survivors_per_100000_scaled_1e6": {
      "unit": "survivors_scaled_1e6",
      "radix": 100000,
      "scale": "stored value / 1000000"
    }
  },
  "storage": {
    "primary_records": "mortality-table-2000cm.json",
    "ordering": "ascending_age",
    "dedupe_key": "age"
  },
  "dataset_id": "mortality-table-2000cm",
  "schema_id": "rates.mortality_table_2000cm.v1",
  "schema_version": 1,
  "proto": {
    "file": "proto/rates/v1/mortality_table.proto",
    "message": "rates.v1.MortalityFile"
  }
}
