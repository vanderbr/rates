{
  "name": "Table 2000CM Mortality Table",
  "source": "Internal Revenue Service",
  "source_page_url": "https://www.irs.gov/retirement-plans/actuarial-tables",
  "source_url": "https://www.irs.gov/pub/irs-tege/table-2000cm.xls",
  "mortality_basis": "2000CM",
  "effective_for_valuations_on_or_after": "2009-05-01",
  "effective_for_valuations_on_or_before": "2023-05-31",
