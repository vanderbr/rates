{
  "name": "Table 2010CM Mortality Table",
  "source": "Internal Revenue Service",
  "source_page_url": "https://www.irs.gov/retirement-plans/actuarial-tables",
  "source_url": "https://www.irs.gov/pub/irs-tege/table-2010cm-final.xlsx",
  "mortality_basis": "2010CM",
  "effective_for_valuations_on_or_after": "2023-06-01",
  "description": "IRS current mortality table derived from mortality experience around 2010.",
  "value_fields": {
    "survivors_per_100000_scaled_1e6": {
      "unit": "survivors_scaled_1e6",
      "radix": 100000,
      "scale": "stored value / 1000000"
    }
  },
  "storage": {
    "primary_records": "mortality-table-2010cm.json",
    "ordering": "ascending_age",
    "dedupe_key": "age"
  },
  "dataset_id": "mortality-table-2010cm",
  "schema_id": "rates.mortality_table_2010cm.v1",
  "schema_version": 1,
  "proto": {
    "file": "proto/rates/v1/mortality_table.proto",
    "message": "rates.v1.MortalityFile"
  }
}
