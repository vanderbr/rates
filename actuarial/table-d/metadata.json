{
  "name": "Table D",
  "source": "Internal Revenue Service",
  "source_page_url": "https://www.irs.gov/retirement-plans/actuarial-tables",
  "source_url": "https://www.irs.gov/pub/irs-tege/table-d.xls",
  "description": "Term unitrust remainder factors.",
  "value_fields": {
    "unitrust_remainder_factor_scaled_1e6": {
      "unit": "factor_scaled_1e6",
      "formula": "(1 - adjusted_payout_rate) ^ term_years",
      "scale": "stored value / 1000000"
    }
  },
  "storage": {
    "manifest_file": "manifest.json",
    "primary_records": "by-interest-rate/NNNNN-basis-points.json",
    "shards": "by-interest-rate/NNNNN-basis-points.json",
    "shard_rate_field": "adjusted_payout_rate_basis_points",
    "ordering": "ascending_time_or_age_key",
    "dedupe_key": [
      "term_years"
    ]
  },
  "dataset_id": "actuarial-table-d",
  "schema_id": "rates.actuarial_table_d.v1",
  "schema_version": 1,
  "proto": {
    "file": "proto/rates/v1/actuarial_table_d.proto",
    "message": "rates.v1.TableDFile"
  }
}
