    "shard_rate_field": "interest_rate_basis_points",
    "ordering": "ascending_time_or_age_key",
    "dedupe_key": [
      "older_age",
      "younger_age"
    ]
  },
  "dataset_id": "actuarial-table-r2",
  "schema_id": "rates.actuarial_table_r2.v1",
  "schema_version": 1,
  "proto": {
    "file": "proto/rates/v1/actuarial_table_r2.proto",
    "message": "rates.v1.TableR2File"
  }
