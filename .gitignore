# Repo-specific local source downloads.
# Canonical repository data is deterministic JSON plus generated protobuf
# shards. Official IRS/Treasury/NY Fed source workbooks, PDFs, CSV exports,
# extracted text, and HTML snapshots should be fetched by the updaters or kept
# under /tmp, not committed as local artifacts.
rates-actuarial-source/
actuarial-source/
source-workbooks/
irs-source/
market-source/
source-cache/
.source-cache/
*.xls
*.xlsx
*.pdf
*.csv
*.desc
*.descriptor

# Publishable generated data-contract artifacts. Keep these explicitly
# trackable even if future ignore rules grow broader.
!index.json
!schemas/
!schemas/**/*.json
!proto/
!proto/**/*.proto
!**/manifest.json
!**/metadata.json
!**/rates.json
!**/protobuf/
!**/protobuf/*.pb

# Keep intentional test fixtures tracked even though source snapshots are
# ignored elsewhere.
!scripts/fixtures/*.txt
!scripts/fixtures/*.html
